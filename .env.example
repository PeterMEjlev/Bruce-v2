# Picovoice Access Key — get free at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here

# OpenAI API Key — must have Realtime API access
OPENAI_API_KEY=sk-...

# Path to your custom "Bruce" wake word model (.ppn file)
# Download from https://console.picovoice.ai/ after training "Bruce"
# Platform-specific — pick the right one for your OS:
#   Windows:      Bruce_en_windows_v3_0_0.ppn
#   Linux/Pi:     Bruce_en_raspberry-pi_v3_0_0.ppn
#   macOS:        Bruce_en_mac_v3_0_0.ppn
WAKE_WORD_PATH=./wake-words/Bruce_en_windows_v3_0_0.ppn

# TTS voice for OpenAI Realtime (alloy | echo | fable | onyx | nova | shimmer)
BRUCE_VOICE=alloy

# System prompt (optional override)
BRUCE_SYSTEM_PROMPT=You are Bruce, a helpful AI assistant for a home brewing setup. Keep responses concise and conversational — you are speaking, not writing.
